---
interface Props {
    title: string;
    description: string;
    cta: { label: string; href: string };
    images: { src: string; alt: string }[];
}

const { title, description, cta, images } = Astro.props;
---

<section class="club-section" id="club">
    <div class="club-inner">
        <div class="club-left">
            <h2 class="club-title">{title}</h2>
            <div class="club-divider"></div>
            <p class="club-description">{description}</p>
            <a href={cta.href} class="club-btn">{cta.label.toUpperCase()}</a>
        </div>
        <div class="club-right">
            {images.map((img) => (
                <div class="club-photo">
                    {img.src ? (
                        <img src={img.src} alt={img.alt} />
                    ) : (
                        <div class="club-photo-placeholder" aria-label={img.alt}>
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                                <rect x="3" y="3" width="18" height="18" rx="2"/>
                                <circle cx="8.5" cy="8.5" r="1.5"/>
                                <path d="M21 15l-5-5L5 21"/>
                            </svg>
                        </div>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .club-section {
        background: #faf8f5;
        padding: 5rem 0;
        width: 100%;
    }

    .club-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 5%;
        display: flex;
        align-items: center;
        gap: 4rem;
    }

    /* LEFT */
    .club-left {
        flex: 0 0 340px;
    }

    .club-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2rem, 3vw, 2.8rem);
        font-weight: 700;
        color: #1c1712;
        line-height: 1.2;
        margin: 0 0 0.75rem 0;
    }

    .club-divider {
        width: 40px;
        height: 2px;
        background: #b8924a;
        margin-bottom: 1.25rem;
    }

    .club-description {
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        color: #4a3f35;
        line-height: 1.8;
        margin-bottom: 2rem;
    }

    .club-btn {
        display: inline-block;
        padding: 0.75rem 1.75rem;
        border: 1.5px solid #b8924a;
        color: #b8924a;
        font-family: 'Inter', sans-serif;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-decoration: none;
        text-transform: uppercase;
        transition: background 0.2s, color 0.2s;
    }

    .club-btn:hover {
        background: #b8924a;
        color: #fff;
    }

    /* RIGHT */
    .club-right {
        flex: 1;
        display: flex;
        gap: 1rem;
        align-items: stretch;
    }

    .club-photo {
        flex: 1;
        aspect-ratio: 3 / 4;
        overflow: hidden;
        border-radius: 2px;
    }

    .club-photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
    }

    .club-photo-placeholder {
        width: 100%;
        height: 100%;
        background: #e8e0d5;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #b8924a;
        min-height: 260px;
    }

    @media (max-width: 900px) {
        .club-inner {
            flex-direction: column;
            gap: 2.5rem;
        }

        .club-left {
            flex: unset;
            width: 100%;
        }

        .club-right {
            width: 100%;
        }
    }

    @media (max-width: 600px) {
        .club-right {
            gap: 0.5rem;
        }
    }
</style>
