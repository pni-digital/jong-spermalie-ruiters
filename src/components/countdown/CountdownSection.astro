---
import countdownBg from '../../assets/images/countdown-bg.png';

interface Props {
    title: string;
    date: string;
    location: string;
    eventSlug: string;
}

const { title, date, location, eventSlug } = Astro.props;
---

<section class="countdown-section">
    <img src={countdownBg.src} alt="" class="countdown-bg-img" aria-hidden="true" />
    <div class="countdown-overlay"></div>
    <div class="countdown-inner">
        <div class="countdown-left">
            <p class="countdown-eyebrow">WE KIJKEN ERNAAR UIT</p>
            <h2 class="countdown-title">{title}</h2>
            <div class="countdown-divider"></div>
            <p class="countdown-description">
                Nog even geduld... het wordt opnieuw<br />een weekend om naar uit te kijken.
            </p>
            <a href={`/events/${eventSlug}`} class="countdown-btn">ONTDEK HET TORNOOI</a>
        </div>

        <div class="countdown-separator"></div>

        <div class="countdown-right">
            <div class="countdown-timer" id="countdown-timer">
                <div class="countdown-unit">
                    <span class="countdown-number" id="cd-days">--</span>
                    <span class="countdown-label">DAGEN</span>
                </div>
                <div class="countdown-unit">
                    <span class="countdown-number" id="cd-hours">--</span>
                    <span class="countdown-label">UREN</span>
                </div>
                <div class="countdown-unit">
                    <span class="countdown-number" id="cd-minutes">--</span>
                    <span class="countdown-label">MINUTEN</span>
                </div>
                <div class="countdown-unit">
                    <span class="countdown-number" id="cd-seconds">--</span>
                    <span class="countdown-label">SECONDEN</span>
                </div>
            </div>
            <p class="countdown-tagline">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="display:inline;vertical-align:middle;margin-right:6px;">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
                Samen maken we er iets moois van.
            </p>
        </div>
    </div>
</section>

<script define:vars={{ eventDate: date }}>
    function pad(n) {
        return String(n).padStart(2, '0');
    }

    function tick() {
        const now = Date.now();
        const target = new Date(eventDate).getTime();
        const diff = target - now;

        const daysEl = document.getElementById('cd-days');
        const hoursEl = document.getElementById('cd-hours');
        const minutesEl = document.getElementById('cd-minutes');
        const secondsEl = document.getElementById('cd-seconds');

        if (!daysEl) return;

        if (diff <= 0) {
            daysEl.textContent = '00';
            hoursEl.textContent = '00';
            minutesEl.textContent = '00';
            secondsEl.textContent = '00';
            return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        daysEl.textContent = pad(days);
        hoursEl.textContent = pad(hours);
        minutesEl.textContent = pad(minutes);
        secondsEl.textContent = pad(seconds);
    }

    tick();
    setInterval(tick, 1000);
</script>

<style>
    .countdown-section {
        position: relative;
        padding: 4rem 0;
        width: 100%;
        overflow: hidden;
        /* Overlap over de hero */
        margin-top: -160px;
        z-index: 10;
        box-shadow: 0 -30px 80px rgba(0, 0, 0, 0.5);
    }

    .countdown-bg-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        z-index: 0;
        display: block;
    }

    .countdown-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        background: linear-gradient(
            to right,
            rgba(20, 13, 4, 0.88) 0%,
            rgba(30, 20, 8, 0.75) 50%,
            rgba(20, 13, 4, 0.82) 100%
        );
        pointer-events: none;
    }

    .countdown-inner {
        position: relative;
        z-index: 2;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 5%;
        display: flex;
        align-items: center;
        gap: 4rem;
    }

    .countdown-left {
        flex: 0 0 460px;
    }

    .countdown-eyebrow {
        font-family: 'Inter', sans-serif;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        color: #b8924a;
        text-transform: uppercase;
        margin: 0 0 0.5rem 0;
    }

    .countdown-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.75rem, 2.8vw, 2.4rem);
        font-weight: 700;
        color: #f5f0e8;
        line-height: 1.2;
        margin: 0 0 0.75rem 0;
    }

    .countdown-divider {
        width: 48px;
        height: 2px;
        background: #b8924a;
        margin-bottom: 1rem;
    }

    .countdown-description {
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        color: #f5f0e8;
        line-height: 1.7;
        margin-bottom: 1.75rem;
    }

    .countdown-btn {
        display: inline-block;
        padding: 0.75rem 1.75rem;
        border: 1.5px solid #b8924a;
        color: #b8924a;
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-decoration: none;
        text-transform: uppercase;
        transition: background 0.2s, color 0.2s;
    }

    .countdown-btn:hover {
        background: #b8924a;
        color: #1c1712;
    }

    .countdown-separator {
        width: 1px;
        height: 180px;
        background: rgba(184, 146, 74, 0.3);
        flex-shrink: 0;
    }

    .countdown-right {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    .countdown-timer {
        display: flex;
        gap: 3rem;
        align-items: flex-start;
    }

    .countdown-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
    }

    .countdown-number {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        color: #f5f0e8;
        line-height: 1;
    }

    .countdown-label {
        font-family: 'Inter', sans-serif;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        color: #b8924a;
        text-transform: uppercase;
    }

    .countdown-tagline {
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        color: #f5f0e8;
    }

    .countdown-tagline svg {
        color: #b8924a;
    }

    @media (max-width: 900px) {
        .countdown-left {
            flex: 0 0 360px;
        }
    }

    @media (max-width: 768px) {
        .countdown-section {
            margin-top: -40px;
        }

        .countdown-inner {
            flex-direction: column;
            gap: 2.5rem;
            text-align: center;
        }

        .countdown-left {
            flex: unset;
            width: 100%;
        }

        .countdown-divider {
            margin-left: auto;
            margin-right: auto;
        }

        .countdown-separator {
            width: 80%;
            height: 1px;
        }

        .countdown-timer {
            gap: 1.5rem;
        }
    }
</style>
